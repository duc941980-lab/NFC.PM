# Supabase project URL, lấy tại Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/publishable key. Được phép dùng ở frontend, KHÔNG dùng service_role key ở frontend.
VITE_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# Gemini API key cho AI assistant phía server. Không bắt buộc nếu chưa dùng AI.
# Lấy tại Google AI Studio, rồi paste vào Render/Railway env var.
GEMINI_API_KEY=your-gemini-api-key

# URL production sau khi deploy, ví dụ https://nfc-pm.onrender.com
APP_URL=http://localhost:5173

# Port local/server. Render sẽ tự cấp PORT nên thường không cần sửa.
PORT=3000
VITE_GEMINI_API_KEY=your-gemini-api-key
NODE_ENV=production